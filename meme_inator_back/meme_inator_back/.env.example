# .env file
# Django Core
SECRET_KEY=your-super-secret-django-key-here

# Database
DB_NAME=meme_inator
DB_USER=root_name
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Email (when you move to production)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=accounts@meme-inator.com

# JWT (optional but good practice)
JWT_SECRET_KEY=another-secret-for-jwt

# API Keys (for when you add them)
APPLE_IAP_PRIVATE_KEY_PATH=/path/to/key
APPLE_IAP_ISSUER_ID_PATH=/path/to/issuer
APPLE_IAP_KEY_ID_PATH=/path/to/key-id
APPLE_IAP_BUNDLE_ID_PATH=/path/to/bundle

# Feature flags
DEBUG=False  # In production
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com